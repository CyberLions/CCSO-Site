HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# SSO (Authentik OIDC) - see https://github.com/yasudacloud/strapi-plugin-sso
SSO_ENABLED=true
SSO_REMEMBER_ME=false
SSO_USE_WHITELIST=false
SSO_OIDC_CLIENT_ID=tobemodified
SSO_OIDC_CLIENT_SECRET=tobemodified
SSO_OIDC_REDIRECT_URI=http://localhost:1337/strapi-plugin-sso/oidc/callback
SSO_OIDC_SCOPES="openid profile email"
SSO_OIDC_AUTHORIZATION_ENDPOINT=https://authentik.example.com/application/o/authorize/
SSO_OIDC_TOKEN_ENDPOINT=https://authentik.example.com/application/o/token/
SSO_OIDC_USER_INFO_ENDPOINT=https://authentik.example.com/application/o/userinfo/
SSO_OIDC_USER_INFO_ENDPOINT_WITH_AUTH_HEADER=true
SSO_OIDC_GRANT_TYPE=authorization_code
SSO_OIDC_FAMILY_NAME_FIELD=family_name
SSO_OIDC_GIVEN_NAME_FIELD=given_name
